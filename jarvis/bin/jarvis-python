#!/usr/bin/env bash
# Run JARVIS with the correct CPU architecture on Apple Silicon.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
PY="$ROOT/jarvis/.venv/bin/python"

export PYTHONNOUSERSITE=1
unset PYTHONPATH
cd "$ROOT"

if [[ ! -x "$PY" ]]; then
  "$ROOT/jarvis/setup.sh"
fi

if [[ "$(uname -m)" == "arm64" ]]; then
  exec arch -arm64 "$PY" "$@"
fi
exec "$PY" "$@"
