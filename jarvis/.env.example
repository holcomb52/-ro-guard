# Optional overrides for JARVIS (defaults load ../.env from RO Guard)
# SUPABASE_URL=
# SUPABASE_KEY=

# Local Ollama
JARVIS_OLLAMA_HOST=http://127.0.0.1:11434
JARVIS_OLLAMA_MODEL=llama3.2
JARVIS_PORT=8765
JARVIS_REVIEW_LIMIT=2000

# Hands-free wake word
JARVIS_WAKE_WORD=hey_jarvis
JARVIS_WAKE_THRESHOLD=0.35
JARVIS_WAKE_ACK=Yes? I'm listening.
JARVIS_WHISPER_SIZE=base
JARVIS_TTS_VOICE=Samantha
