SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_publishable_key

# Public URL where users open RO Shield (password reset links in email)
RO_SHIELD_APP_URL=http://localhost:8531

# Streamlit Cloud toolbar (Share, Manage app) and Deployment & Secrets — owner login(s) only.
RO_SHIELD_OWNER_EMAIL=holcomb52@yahoo.com

# Production (Streamlit Cloud): set the same key in app Secrets, e.g.
# RO_SHIELD_APP_URL=https://ro-guard.streamlit.app

# Supabase: enable Email auth + SMTP (Outlook, Gmail, or Yahoo) — see docs/SUPABASE_SMTP.md
# Redirect URLs in Supabase must include RO_SHIELD_APP_URL/**

# Scheduled Reporting PDF emails — see docs/SCHEDULED_REPORTS.md
# REPORT_SMTP_HOST=smtp.office365.com
# REPORT_SMTP_PORT=587
# REPORT_SMTP_USER=reports@yourdealership.com
# REPORT_SMTP_PASSWORD=your_app_password
# REPORT_SMTP_FROM=reports@yourdealership.com
# REPORT_SMTP_USE_TLS=true
